pipeline {

    agent any


    environment {

        AZURE_CREDENTIALS = credentials('azure-jenkins-sp')

        ARM_CLIENT_ID       = "${AZURE_CREDENTIALS_USR}"
        ARM_CLIENT_SECRET   = "${AZURE_CREDENTIALS_PSW}"

        ARM_SUBSCRIPTION_ID = "2297facf-380e-42bd-9369-85795a0b1251"
        ARM_TENANT_ID       = "84981200-0704-4e2c-82ff-c288b51bc012"

    }


    stages {


        stage('Checkout Code') {

            steps {

                checkout scm

            }
        }



        stage('Check Terraform') {

            steps {

                sh '''
                echo "Checking Terraform installation"

                terraform version
                '''

            }
        }



        stage('Azure Login Validation') {

            steps {

                sh '''
                echo "Testing Azure Service Principal login"


                az login \
                --service-principal \
                -u "\\$ARM_CLIENT_ID" \
                -p "\\$ARM_CLIENT_SECRET" \
                -t "\\$ARM_TENANT_ID" >/dev/null


                az account set \
                --subscription "\\$ARM_SUBSCRIPTION_ID"


                az account show

                '''

            }
        }




        stage('Terraform Init') {

            steps {

                sh '''
                terraform init
                '''

            }
        }



        stage('Terraform Validate') {

            steps {

                sh '''
                terraform validate
                '''

            }
        }





        stage('Terraform Plan') {

            steps {

                sh '''
                terraform plan \
                -out=tfplan

                '''

            }
        }





        stage('Terraform Apply') {

            when {
                branch 'main'
            }


            steps {

                input message: 'Approve Azure Container App deployment?'


                sh '''

                terraform apply \
                -auto-approve \
                tfplan

                '''

            }
        }





        stage('Terraform Output') {

            steps {

                sh '''

                echo "Deployment Output"

                terraform output

                '''

            }
        }

    }



    post {


        success {

            echo "Azure Container App provisioning completed successfully"

        }


        failure {

            echo "Azure Container App provisioning failed"

        }


        always {

            sh '''

            az logout || true

            '''

        }

    }

}
