pipeline {

    agent any


    stages {


        stage('Checkout') {

            steps {

                checkout scm

            }
        }



        stage('Terraform Version Check') {

            steps {

                sh '''

                set -eu

                echo "Checking Terraform version"

                terraform version

                '''

            }
        }




        stage('Azure Login') {

            steps {


                withCredentials([

                    azureServicePrincipal('azure-jenkins-sp')

                ]) {


                    sh '''

                    set -eu


                    echo "Logging into Azure"


                    az login \
                    --service-principal \
                    -u "$AZURE_CLIENT_ID" \
                    -p "$AZURE_CLIENT_SECRET" \
                    -t "$AZURE_TENANT_ID" >/dev/null



                    az account set \
                    --subscription "$AZURE_SUBSCRIPTION_ID"



                    az account show


                    '''

                }

            }
        }





        stage('Terraform Init') {

            steps {

                sh '''

                set -eu

                terraform init

                '''

            }
        }





        stage('Terraform Validate') {

            steps {

                sh '''

                set -eu

                terraform validate

                '''

            }
        }





        stage('Terraform Plan') {

            steps {


                withCredentials([

                    azureServicePrincipal('azure-jenkins-sp')

                ]) {


                    sh '''

                    set -eu


                    export ARM_CLIENT_ID="$AZURE_CLIENT_ID"
                    export ARM_CLIENT_SECRET="$AZURE_CLIENT_SECRET"
                    export ARM_TENANT_ID="$AZURE_TENANT_ID"
                    export ARM_SUBSCRIPTION_ID="$AZURE_SUBSCRIPTION_ID"



                    terraform plan \
                    -out=tfplan


                    '''

                }

            }

        }





        stage('Terraform Apply') {


            when {

                branch 'main'

            }


            steps {


                input message: 'Approve Terraform Apply?'



                withCredentials([

                    azureServicePrincipal('azure-jenkins-sp')

                ]) {


                    sh '''

                    set -eu


                    export ARM_CLIENT_ID="$AZURE_CLIENT_ID"
                    export ARM_CLIENT_SECRET="$AZURE_CLIENT_SECRET"
                    export ARM_TENANT_ID="$AZURE_TENANT_ID"
                    export ARM_SUBSCRIPTION_ID="$AZURE_SUBSCRIPTION_ID"



                    terraform apply \
                    -auto-approve \
                    tfplan


                    '''

                }

            }

        }





        stage('Terraform Output') {


            steps {


                sh '''

                echo "Terraform Outputs"

                terraform output


                '''

            }

        }


    }



    post {


        success {

            echo "Azure Container App infrastructure deployed successfully"

        }


        failure {

            echo "Terraform deployment failed"

        }


        always {

            sh '''

            az logout || true

            '''

        }

    }

}
